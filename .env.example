POSTGRES_PASSWORD=axene_templates_dev

# Host dev (run Postgres via docker-compose; run app via `npm run dev`):
DATABASE_URL=postgresql://axene_templates:axene_templates_dev@localhost:5436/axene_templates

# Docker (run app+db via `docker compose up -d`):
DATABASE_URL_DOCKER=postgresql://axene_templates:axene_templates_dev@postgres:5432/axene_templates

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=
# Google OAuth callback. Must EXACTLY match an Authorized redirect URI in the
# Google Cloud console for this client. Dev (vite) uses :5173; docker dev uses
# :3004. Production is https://templates.axene.io/auth/google/callback (this is
# the docker-compose default, so prod needs no override).
OAUTH_REDIRECT_URL=http://localhost:5173/auth/google/callback
